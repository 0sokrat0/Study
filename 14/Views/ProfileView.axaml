<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Cinema.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="Cinema.Views.ProfileView"
             x:DataType="vm:ProfileViewModel">

    <DockPanel Margin="20">
        <StackPanel DockPanel.Dock="Top" Spacing="10" Margin="0,0,0,20">
            <TextBlock Text="Личный кабинет" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="{Binding User.Name, StringFormat='Имя: {0}'}" FontSize="18"/>
            <TextBlock Text="{Binding User.Email, StringFormat='Email: {0}'}" FontSize="16"/>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Content="Выйти" Command="{Binding LogoutCommand}" Width="100"/>
                <Button Content="Назад" Command="{Binding GoBackCommand}" Width="100"/>
            </StackPanel>
        </StackPanel>

        <ScrollViewer>
            <StackPanel Spacing="10">
                <TextBlock Text="Мои билеты" FontSize="20" FontWeight="Bold"/>
                <ItemsControl ItemsSource="{Binding Tickets}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="5" Padding="15" BorderBrush="Gray" BorderThickness="1" CornerRadius="5">
                                <StackPanel Spacing="5">
                                    <TextBlock Text="{Binding Movie.Title}" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Session.DateTime, StringFormat='Дата и время: {0:dd.MM.yyyy HH:mm}'}"/>
                                    <TextBlock Text="{Binding Hall.Name, StringFormat='Зал: {0}'}"/>
                                    <TextBlock Text="{Binding Seat.Row, StringFormat='Ряд: {0}'}"/>
                                    <TextBlock Text="{Binding Seat.Number, StringFormat='Место: {0}'}"/>
                                    <TextBlock Text="{Binding Seat.Price, StringFormat='Цена: {0} руб.'}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>

</UserControl>
