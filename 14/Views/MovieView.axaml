<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Cinema.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="Cinema.Views.MovieView"
             x:DataType="vm:MovieViewModel">

    <DockPanel Margin="20">
        <Button DockPanel.Dock="Top" Content="← Назад" Command="{Binding GoBackCommand}" Width="100" HorizontalAlignment="Left" Margin="0,0,0,20"/>

        <ScrollViewer>
            <StackPanel Spacing="20">
                <StackPanel Orientation="Horizontal" Spacing="20">
                    <Image Source="{Binding Movie.ImageUrl}" Width="300" Height="450"/>
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding Movie.Title}" FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Movie.Rating, StringFormat='Рейтинг: {0:F1}'}" FontSize="18"/>
                        <TextBlock Text="{Binding Genres, StringFormat='Жанры: {0}'}" FontSize="16"/>
                        <TextBlock Text="{Binding Movie.AgeRating, StringFormat='Возрастной рейтинг: {0}+'}" FontSize="16"/>
                        <TextBlock Text="{Binding Movie.Description}" TextWrapping="Wrap" MaxWidth="500"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="10">
                    <TextBlock Text="Сеансы" FontSize="22" FontWeight="Bold"/>
                    <ItemsControl ItemsSource="{Binding Sessions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="5" Padding="10" BorderBrush="Gray" BorderThickness="1" CornerRadius="5">
                                    <StackPanel Orientation="Horizontal" Spacing="20">
                                        <TextBlock Text="{Binding Session.DateTime, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" Width="150"/>
                                        <TextBlock Text="{Binding Hall.Name}" Width="100"/>
                                        <TextBlock Text="{Binding Hall.Classification}" Width="100"/>
                                        <Button Content="Выбрать место"
                                                Command="{Binding $parent[ItemsControl].((vm:MovieViewModel)DataContext).SelectSessionCommand}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>

</UserControl>
