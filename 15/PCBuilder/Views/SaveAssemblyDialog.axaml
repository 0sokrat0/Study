<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PCBuilder.Views.SaveAssemblyDialog"
        Title="Сохранить сборку"
        Width="400" Height="240"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <Window.Styles>
        <Style Selector="TextBox">
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="TextBlock.Label">
            <Setter Property="Foreground" Value="#AAAACC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Styles>

    <DockPanel Background="#1A1A2E">
        <Border DockPanel.Dock="Bottom" Background="#1E1E30" Padding="16,10" BorderThickness="0,1,0,0" BorderBrush="#3A3A55">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="Отмена" Padding="16,8" CornerRadius="6" Click="OnCancel"/>
                <Button Content="Сохранить" Padding="16,8" CornerRadius="6"
                        Background="#7C6AF5" Foreground="White" Click="OnSave"/>
            </StackPanel>
        </Border>
        <StackPanel Margin="20">
            <TextBlock Text="Название сборки" Classes="Label"/>
            <TextBox x:Name="NameBox" Watermark="Например: Игровой ПК 2024"/>
            <TextBlock Text="Автор" Classes="Label"/>
            <TextBox x:Name="AuthorBox" Watermark="Ваше имя"/>
        </StackPanel>
    </DockPanel>
</Window>
